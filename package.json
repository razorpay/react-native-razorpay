    "open-android": "open example/android -a 'Android Studio.app'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/razorpay/react-native-razorpay.git"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-native": ">=0.66.0"
  },
  "keywords": [
    "react-native",
    "razorpay",
    "payments"
  ],
  "author": "Razorpay Developers <developers@razorpay.com> (https://razorpay.com/)",
