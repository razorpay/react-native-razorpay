      "javaPackageName": "com.razorpay.rn"
    },
    "ios": {
      "outputDir": "ios"
    }
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-native": ">=0.66.0"
  },
  "keywords": [
    "react-native",
    "razorpay",
    "payments"
  ],
  "author": "Razorpay Developers <developers@razorpay.com> (https://razorpay.com/)",
